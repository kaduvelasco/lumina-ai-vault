# ==============================================================================
# .gitignore — lumina-ai-vault
# Projeto: MCP server TypeScript para memória persistente de projetos de IA
# ==============================================================================

# ------------------------------------------------------------------------------
# Sistema operacional
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# IDEs e editores
# ------------------------------------------------------------------------------
.idea/
.vscode/
.vscodium/
.zed/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Dependências
# ------------------------------------------------------------------------------
node_modules/

# ------------------------------------------------------------------------------
# Build e artefatos gerados
# ------------------------------------------------------------------------------
dist/
*.tsbuildinfo
*.js.map
*.d.ts.map

# ------------------------------------------------------------------------------
# Cache e temporários
# ------------------------------------------------------------------------------
.cache/
.tmp/
tmp/
*.log
*.log.*

# ------------------------------------------------------------------------------
# Node / npm
# ------------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.pnp.*

# ------------------------------------------------------------------------------
# Variáveis de ambiente
# ------------------------------------------------------------------------------
.env
.env.*
*.env

# ------------------------------------------------------------------------------
# Credenciais e segurança
# ------------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.*
*.secret
.htpasswd
auth.json
