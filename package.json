{
  "name": "lumina-ai-vault",
  "version": "2.0.0",
  "description": "Lumina AI Vault — MCP server for persistent AI development memory, organizes project knowledge across sessions",
  "keywords": ["mcp", "ai", "memory", "knowledge", "claude", "llm"],
  "homepage": "https://github.com/kaduvelasco/lumina-ai-vault",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaduvelasco/lumina-ai-vault.git"
  },
  "author": "Kadu Velasco",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "lumina-aivault": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "node --eval \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
